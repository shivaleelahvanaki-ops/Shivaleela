        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# -------------------------\n",
        "# Device\n",
        "# -------------------------\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "print(\"Using:\", device)\n",
        "\n",
        "# -------------------------\n",
        "# Create simple dataset\n",
        "# -------------------------\n",
        "num_samples = 5000\n",
        "\n",
        "# Points around (2,2)\n",
        "data = torch.randn(num_samples, 2) * 0.5 + 2\n",
        "data = data.to(device)\n",
        "\n",
        "# -------------------------\n",
        "# Diffusion Parameters\n",
        "# -------------------------\n",
        "T = 100\n",
        "\n",
        "beta = torch.linspace(0.0001, 0.02, T).to(device)\n",
        "alpha = 1 - beta\n",
        "alpha_bar = torch.cumprod(alpha, dim=0)\n",
        "\n",
        "# -------------------------\n",
        "# Forward Diffusion\n",
        "# -------------------------\n",
        "def forward_diffusion(x0, t):\n",
        "    noise = torch.randn_like(x0)\n",
        "\n",
        "    sqrt_alpha_bar = torch.sqrt(alpha_bar[t]).view(-1,1)\n",
        "    sqrt_one_minus = torch.sqrt(1-alpha_bar[t]).view(-1,1)\n",
        "\n",
        "    xt = sqrt_alpha_bar*x0 + sqrt_one_minus*noise\n",
        "\n",
        "    return xt, noise\n",
        "\n",
        "# -------------------------\n",
        "# Neural Network\n",
        "# -------------------------\n",
        "class NoisePredictor(nn.Module):\n",
        "\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "\n",
        "        self.net = nn.Sequential(\n",
        "            nn.Linear(3,64),\n",
        "            nn.ReLU(),\n",
        "\n",
        "            nn.Linear(64,64),\n",
        "            nn.ReLU(),\n",
        "\n",
        "            nn.Linear(64,2)\n",
        "        )\n",
        "\n",
        "    def forward(self,x,t):\n",
        "\n",
        "        t = t.float()/T\n",
        "        t = t.unsqueeze(1)\n",
        "\n",
        "        x = torch.cat([x,t],dim=1)\n",
        "\n",
        "        return self.net(x)\n",
        "\n",
        "model = NoisePredictor().to(device)\n",
        "\n",
        "optimizer = optim.Adam(model.parameters(),lr=0.001)\n",
        "\n",
        "loss_fn = nn.MSELoss()\n",
        "\n",
        "# -------------------------\n",
        "# Training\n",
        "# -------------------------\n",
        "epochs = 100\n",
        "\n",
        "batch_size = 128\n",
        "\n",
        "for epoch in range(epochs):\n",
        "\n",
        "    idx = torch.randint(0,num_samples,(batch_size,))\n",
        "    x0 = data[idx]\n",
        "\n",
        "    t = torch.randint(0,T,(batch_size,),device=device)\n",
        "\n",
        "    xt, noise = forward_diffusion(x0,t)\n",
        "\n",
        "    pred_noise = model(xt,t)\n",
        "\n",
        "    loss = loss_fn(pred_noise,noise)\n",
        "\n",
        "    optimizer.zero_grad()\n",
        "    loss.backward()\n",
        "    optimizer.step()\n",
        "\n",
        "    if epoch%10==0:\n",
        "        print(f\"Epoch {epoch} Loss {loss.item():.5f}\")\n",
        "\n",
        "# -------------------------\n",
        "# Reverse Diffusion\n",
        "# -------------------------\n",
        "\n",
        "x = torch.randn(1000,2).to(device)\n",
        "\n",
        "with torch.no_grad():\n",
        "\n",
        "    for i in reversed(range(T)):\n",
        "\n",
        "        t = torch.full((1000,),i,device=device,dtype=torch.long)\n",
        "\n",
        "        pred_noise = model(x,t)\n",
        "\n",
        "        alpha_t = alpha[i]\n",
        "        alpha_bar_t = alpha_bar[i]\n",
        "        beta_t = beta[i]\n",
        "\n",
        "        if i>0:\n",
        "            z = torch.randn_like(x)\n",
        "        else:\n",
        "            z = torch.zeros_like(x)\n",
        "\n",
        "        x = (1/torch.sqrt(alpha_t))*(\n",
        "            x - ((1-alpha_t)/torch.sqrt(1-alpha_bar_t))*pred_noise\n",
        "        ) + torch.sqrt(beta_t)*z\n",
        "\n",
        "generated = x.cpu()\n",
        "\n",
        "# -------------------------\n",
        "# Plot\n",
        "# -------------------------\n",
        "\n",
        "plt.figure(figsize=(6,6))\n",
        "\n",
        "plt.scatter(\n",
        "    data[:,0].cpu(),\n",
        "    data[:,1].cpu(),\n",
        "    s=5,\n",
        "    label=\"Original\"\n",
        ")\n",
        "\n",
        "plt.scatter(\n",
        "    generated[:,0],\n",
        "    generated[:,1],\n",
        "    s=5,\n",
        "    label=\"Generated\"\n",
        ")\n",
        "\n",
        "plt.legend()\n",
        "plt.title(\"Simple Diffusion Model\")\n",
        "plt.show()"
      ],
